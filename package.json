{
  "name": "boster-bost-panel",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "dev": "next dev --webpack --hostname 127.0.0.1 --port 3000",
    "build": "next build --webpack",
    "start": "next start --hostname 127.0.0.1 --port 3000",
    "lint": "next lint",
    "cloudflare:build": "node scripts/build-cloudflare.mjs",
    "preview": "node scripts/build-cloudflare.mjs && opennextjs-cloudflare preview",
    "deploy": "node scripts/build-cloudflare.mjs && wrangler deploy",
    "cloudflare:d1:schema": "wrangler d1 execute boster-bost --remote --file migrations/0001_cloudflare_d1_initial.sql",
    "cloudflare:d1:export": "node scripts/export-mysql-to-d1.mjs",
    "cloudflare:d1:import": "wrangler d1 execute boster-bost --remote --file cloudflare-d1-data.sql"
  },
  "dependencies": {
    "@getbrevo/brevo": "^5.0.4",
    "mysql2": "^3.22.5",
    "next": "16.3.0-canary.60",
    "nodemailer": "^9.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "wrangler": "^4.106.0"
  }
}
